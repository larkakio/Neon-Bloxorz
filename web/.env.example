# Production site URL (metadata, OG). Vercel: set in project env or leave default in layout.
NEXT_PUBLIC_SITE_URL=https://neon-bloxorz.vercel.app

# Base.dev app id (meta base:app_id). Default is set in layout if unset.
NEXT_PUBLIC_BASE_APP_ID=69c4fbc8875674902db2b29a

# Target chain for "wrong network" banner: 8453 = Base (default), 84532 = Base Sepolia
NEXT_PUBLIC_CHAIN_ID=8453

# Deployed DailyCheckIn (Base mainnet 8453 or Sepolia 84532)
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=

# Base.dev → Builder Code (display id, e.g. bc_…)
NEXT_PUBLIC_BUILDER_CODE=bc_k4ij8vow

# Hex ERC-8021 data suffix for tagged txs (copy from Base.dev integration docs)
NEXT_PUBLIC_BUILDER_CODE_SUFFIX=

# Optional: WalletConnect v2 (https://cloud.walletconnect.com) — adds QR / mobile wallets
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Script: scripts/checkin.ts
PRIVATE_KEY=
# Optional override; defaults to Base Sepolia or Base mainnet public RPC
RPC_URL=
CHAIN_ID=84532
